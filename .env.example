PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
PGSSLMODE=require
JWT_SECRET=change-this-secret
INGEST_HOOK_TOKEN=change-hook-token
SUPPORT_ADMIN_EMAIL=admin@hydra-tech.pro
SUPPORT_ADMIN_PASSWORD=ChangeThisPassword123!
USER_EMAIL_DOMAIN=hydra-tech.pro
# Set to "false" to allow any email domain for portal users (temporary option B).
# When false, user emails are NOT normalized to USER_EMAIL_DOMAIN and can be Gmail/Outlook/etc.
ENFORCE_USER_EMAIL_DOMAIN=true
WHATSAPP_PROVIDER=generic
# Use your custom domain here so magic-link emails point to it (e.g. https://support.yourcompany.com/public/requester/portal)
REQUESTER_PORTAL_BASE_URL=https://it-support-v2.vercel.app/public/requester/portal
REQUESTER_MAGIC_LINK_TTL_MINUTES=20
REQUESTER_LINK_COOLDOWN_SECONDS=60
REQUESTER_SESSION_SECRET=change-requester-session-secret
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@domain.com
SMTP_PASS=your-mailbox-app-password
SMTP_FROM=your-mailbox@domain.com
# Portal frontend URL (use custom domain when configured, e.g. https://support.yourcompany.com)
PORTAL_BASE_URL=https://it-support-v2.vercel.app
PASSWORD_RESET_TTL_MINUTES=60

# Resend email sender (recommended - used for password reset AND requester magic-link/track ticket)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Support Portal <onboarding@resend.dev>

# Microsoft Graph mail sender (recommended over SMTP basic auth)
# App registration must have Mail.Send application permission with admin consent.
M365_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
M365_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
M365_CLIENT_SECRET=your-client-secret
M365_SENDER_UPN=your-mailbox@domain.com
