PORT=5000

# Core backend
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR_DB_PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
PGSSLMODE=require
JWT_SECRET=replace-with-long-random-secret
INGEST_HOOK_TOKEN=replace-with-strong-hook-token

# Default admin seed (used only when DB has no users)
SUPPORT_ADMIN_EMAIL=admin@hydra-tech.com
SUPPORT_ADMIN_PASSWORD=ChangeThisPassword123!

# Channels
WHATSAPP_PROVIDER=generic

# Public requester portal (passwordless)
REQUESTER_PORTAL_BASE_URL=https://it-support-v2.vercel.app/public/requester/portal
REQUESTER_MAGIC_LINK_TTL_MINUTES=20
REQUESTER_LINK_COOLDOWN_SECONDS=60
REQUESTER_SESSION_SECRET=replace-with-long-random-requester-secret

# SMTP (Outlook.com)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=Mohamed.client2022@outlook.com
SMTP_PASS=replace-with-outlook-app-password
SMTP_FROM=Mohamed.client2022@outlook.com
