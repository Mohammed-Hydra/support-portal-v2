{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/api", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
